FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application     {{ solver_name }};

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         {{ end_time }};

deltaT          1;

writeControl    timeStep;

writeInterval   {{ write_interval }};

purgeWrite      3;

writeFormat     ascii;

writePrecision  8;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

functions
{
    probes
    {
        type            probes;
        libs            (sampling);
        writeControl    timeStep;
        writeInterval   {{ write_interval }};
        probeLocations
        (
{% for probe in probes %}
            ({{ probe.x }} {{ probe.y }} {{ probe.z }})  // {{ probe.name }}
{% endfor %}
        );
        fields
        (
            T
            U
        );
    }
}
