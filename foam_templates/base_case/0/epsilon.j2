FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      epsilon;
}

dimensions      [0 2 -3 0 0 0 0];

internalField   uniform 0.01;

boundaryField
{
    "(floor|ceiling|heater_wall|opposite_wall|front|back)"
    {
        type            epsilonWallFunction;
        value           uniform 0.01;
    }
}
